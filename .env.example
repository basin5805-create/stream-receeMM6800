# Frontend
FRONTEND_PORT=15281
NEXTAUTH_URL=http://localhost:15281/
NEXTAUTH_SECRET=change-me-before-real-use
AUTH_SECRET=change-me-before-real-use

# Backend
BACKEND_PORT=12555
BACKEND_DB_DIR=./runtime/db
BACKEND_OUTPUT_DIR=./runtime/output
BACKEND_CONFIG_FILE=./config/backend.config.json

# Optional runtime paths for Windows host mode
JAVA_BIN=
PYTHON_BIN=
FFMPEG_BIN=

# Optional proxy configuration
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,host.docker.internal,www.xiaohongshu.com,xiaohongshu.com,.xiaohongshu.com,live.xhscdn.com,live-play.xhscdn.com,live-source-play.xhscdn.com,live-source-play-bak-tx.xhscdn.com,.xhscdn.com
